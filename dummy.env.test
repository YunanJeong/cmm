# central_monitor 테스트용 더미 환경변수
# 사용법: source .env.test 후 envsubst < central_monitor_v86.yaml | helm ...
#
# grafana 13부터 contactPoint provisioning 검증이 강화돼,
# ${MY_MAIL} 등이 비어있으면 grafana 컨테이너가 startup에서 fail한다.
# 테스트 환경에서 실제값을 넣을 필요 없을 때 이 더미값으로 우회.

export GRAFANA_ADMIN=dummypw
export MY_EKS_DNS=eks.dummy.local
export MY_EKS_LOKI=loki.dummy.local
export MY_SMTP_SVR=smtp.dummy.local:25
export MY_MAIL=dummy@example.com
export TEAMS_WEBHOOK=https://teams.dummy.local/webhook
export LINE_TOKEN=dummytoken
